{
  "statusCheck": true,
  "statusCommentsEnabled": true,
  "triggerOnUpdates": true,
  "includeBranches": ["main"],
  "include": [
    "apps/**",
    "packages/**",
    "docs/**",
    "scripts/**",
    "*.md",
    "*.json",
    "*.ts",
    "*.tsx",
    "*.yaml",
    "*.yml"
  ],
  "exclude": [
    "pnpm-lock.yaml",
    "out/**",
    "dist/**",
    "apps/desktop/out/**",
    "apps/desktop/dist/**",
    "apps/desktop/public/ghostty-vt.wasm",
    "node_modules/**"
  ]
}
