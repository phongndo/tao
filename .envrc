# direnv — Auto-load dev environment when you cd into this repo.
# https://direnv.net
#
# This tries mise first (lightweight), falls back to Nix flake.
# If you have both, mise wins for speed.

# ── mise (preferred — faster, simpler) ──
if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
  if [ -f .mise.toml ]; then
    mise trust 2>/dev/null || true
    eval "$(mise hook-env -s bash)"
  fi

# ── Nix flake (fallback — reproducible, heavier) ──
elif command -v nix &>/dev/null && [ -f flake.nix ]; then
  use flake
else
  echo "⚠️  Install mise (https://mise.jdx.dev) or Nix for a reproducible dev environment."
fi
