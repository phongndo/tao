{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "includes": [
      "src/**/*.ts",
      "src/**/*.js",
      "src/**/*.json",
      "src/**/*.css",
      "src/**/*.md",
      "src/**/*.yml",
      "src/**/*.yaml",
      "src/**/*.html",
      "bench/**/*.ts",
      "docs/**/*.md",
      "*.json",
      "*.md",
      "*.ts",
      "*.yml",
      "*.yaml"
    ]
  },
  "linter": {
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      }
    },
    "includes": ["src/**/*.ts", "src/**/*.js", "bench/**/*.ts", "*.ts"]
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "files": {
    "maxSize": 1048576,
    "ignoreUnknown": true
  },
  "vcs": {
    "useIgnoreFile": true,
    "root": "."
  }
}
