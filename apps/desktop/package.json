{
  "name": "@tao/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "A performance-first workspace terminal powered by Electron and Ghostty Web",
  "keywords": [
    "electron",
    "emulator",
    "ghostty",
    "terminal"
  ],
  "license": "MIT",
  "author": "Tao Contributors",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "tsx ../../scripts/electron-install.ts",
    "build:taod": "pnpm --filter @tao/daemon build",
    "dev": "pnpm build:taod && electron-vite dev",
    "build": "pnpm build:taod && electron-vite build",
    "preview": "electron-vite preview",
    "prestart": "tsx ../../scripts/electron-install.ts",
    "start": "electron .",
    "bench": "tsx bench/benchmark.ts",
    "bench:latency": "bash bench/latency-bench.sh",
    "bench:ipc": "tsx bench/run-electron.ts bench/ipc-benchmark.ts",
    "bench:cross": "bash bench/cross-terminal.sh",
    "bench:startup": "bash bench/startup-bench.sh",
    "bench:all": "bash bench/run-all.sh",
    "test:persistence": "tsx --test src/main/taod-stream.test.ts",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . --jsx-a11y-plugin --deny-warnings --report-unused-disable-directives",
    "lint:fix": "oxlint . --jsx-a11y-plugin --fix",
    "check": "pnpm lint && pnpm fmt:check && pnpm tsc",
    "check:fix": "pnpm lint:fix && pnpm fmt",
    "tsc": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@tao/shared": "workspace:*",
    "effect": "4.0.0-beta.66",
    "ghostty-web": "0.4.0-next.14.g6a1a50d",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-mosaic-component": "6.2.0",
    "react-resizable-panels": "^4.11.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.0.1",
    "electron-vite": "^5.0.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.4"
}
