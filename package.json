{
  "name": "tao",
  "version": "1.0.0",
  "private": true,
  "description": "A performance-first workspace terminal powered by Electron and Ghostty Web",
  "keywords": [
    "electron",
    "emulator",
    "ghostty",
    "terminal"
  ],
  "license": "MIT",
  "author": "Tao Contributors",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @tao/desktop dev",
    "build": "pnpm --filter @tao/desktop build",
    "preview": "pnpm --filter @tao/desktop preview",
    "start": "pnpm --filter @tao/desktop start",
    "build:taod": "pnpm --filter @tao/daemon build",
    "test:taod": "pnpm --filter @tao/daemon test",
    "zig:build": "pnpm --filter @tao/daemon build",
    "zig:test": "pnpm --filter @tao/daemon test",
    "zig:lint": "pnpm --filter @tao/daemon lint",
    "zig:fmt": "pnpm --filter @tao/daemon fmt",
    "zig:fmt:check": "pnpm --filter @tao/daemon fmt:check",
    "zig:lsp": "pnpm --filter @tao/daemon lsp",
    "zig:check": "pnpm zig:lint && pnpm zig:fmt:check && pnpm zig:test",
    "bench": "pnpm --filter @tao/desktop bench",
    "bench:latency": "pnpm --filter @tao/desktop bench:latency",
    "bench:ipc": "pnpm --filter @tao/desktop bench:ipc",
    "bench:cross": "pnpm --filter @tao/desktop bench:cross",
    "bench:startup": "pnpm --filter @tao/desktop bench:startup",
    "bench:all": "pnpm --filter @tao/desktop bench:all",
    "test:persistence": "pnpm --filter @tao/desktop test:persistence",
    "postinstall": "node scripts/fix-node-pty-perms.mjs && node scripts/fix-electron-install.mjs",
    "fmt": "pnpm fmt:ts && pnpm zig:fmt",
    "fmt:check": "pnpm fmt:ts:check && pnpm zig:fmt:check",
    "fmt:ts": "pnpm exec oxfmt .",
    "fmt:ts:check": "pnpm exec oxfmt --check .",
    "fmt:nix": "nix develop --command nixpkgs-fmt flake.nix",
    "fmt:nix:check": "nix develop --command nixpkgs-fmt --check flake.nix",
    "lint": "pnpm --filter @tao/desktop --filter @tao/shared lint && pnpm zig:lint",
    "lint:fix": "pnpm --filter @tao/desktop --filter @tao/shared lint:fix",
    "check": "pnpm lint && pnpm fmt:check && pnpm tsc && pnpm test:persistence && pnpm zig:test",
    "check:fix": "pnpm lint:fix && pnpm fmt",
    "tsc": "pnpm --filter @tao/desktop tsc"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "oxfmt": "^0.49.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
