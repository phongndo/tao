{
  "name": "tau",
  "version": "1.0.0",
  "description": "A super-performant terminal emulator built with Electron + ghostty-web",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "bench": "npx tsx bench/benchmark.ts",
    "bench:latency": "bash bench/latency-bench.sh",
    "bench:cross": "bash bench/cross-terminal.sh",
    "bench:startup": "bash bench/startup-bench.sh",
    "bench:all": "bash bench/run-all.sh",
    "fmt": "biome format --write src/",
    "fmt:check": "biome format src/",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "tsc": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "keywords": [
    "terminal",
    "emulator",
    "electron",
    "ghostty"
  ],
  "author": "Tau Contributors",
  "license": "MIT OR Apache-2.0",
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^25.7.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.0.1",
    "electron-vite": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ghostty-web": "0.4.0-next.14.g6a1a50d",
    "node-pty": "^1.1.0"
  }
}
