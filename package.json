{
  "name": "tau",
  "version": "1.0.0",
  "description": "A super-performant terminal emulator built with Electron + ghostty-web",
  "keywords": [
    "electron",
    "emulator",
    "ghostty",
    "terminal"
  ],
  "license": "MIT OR Apache-2.0",
  "author": "Tau Contributors",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "bench": "tsx bench/benchmark.ts",
    "bench:latency": "bash bench/latency-bench.sh",
    "bench:ipc": "electron bench/ipc-benchmark.mjs",
    "bench:cross": "bash bench/cross-terminal.sh",
    "bench:startup": "bash bench/startup-bench.sh",
    "bench:all": "bash bench/run-all.sh",
    "postinstall": "node scripts/fix-node-pty-perms.mjs",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . --jsx-a11y-plugin --deny-warnings --report-unused-disable-directives",
    "lint:fix": "oxlint . --jsx-a11y-plugin --fix",
    "check": "pnpm lint && pnpm fmt:check",
    "check:fix": "pnpm lint:fix && pnpm fmt",
    "tsc": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "effect": "4.0.0-beta.66",
    "ghostty-web": "0.4.0-next.14.g6a1a50d",
    "lucide-react": "^1.16.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-mosaic-component": "6.2.0",
    "react-resizable-panels": "^4.11.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.0.1",
    "electron-vite": "^5.0.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
