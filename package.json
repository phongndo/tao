{
  "name": "tau",
  "version": "1.0.0",
  "description": "A super-performant terminal emulator built with Electron + ghostty-web",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "bench": "tsx bench/benchmark.ts",
    "bench:latency": "bash bench/latency-bench.sh",
    "bench:ipc": "electron bench/ipc-benchmark.mjs",
    "bench:cross": "bash bench/cross-terminal.sh",
    "bench:startup": "bash bench/startup-bench.sh",
    "bench:all": "bash bench/run-all.sh",
    "postinstall": "node scripts/fix-node-pty-perms.mjs",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "tsc": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "keywords": [
    "terminal",
    "emulator",
    "electron",
    "ghostty"
  ],
  "author": "Tau Contributors",
  "license": "MIT OR Apache-2.0",
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.0.1",
    "electron-vite": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "effect": "^3.21.2",
    "ghostty-web": "0.4.0-next.14.g6a1a50d",
    "lucide-react": "^1.16.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-mosaic-component": "6.2.0",
    "react-resizable-panels": "^4.11.1",
    "zustand": "^5.0.13"
  }
}
