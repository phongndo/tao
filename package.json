{
  "name": "tau",
  "version": "1.0.0",
  "private": true,
  "description": "A performance-first workspace terminal powered by Electron and xterm.js WebGL",
  "keywords": [
    "electron",
    "emulator",
    "terminal",
    "xterm"
  ],
  "license": "MIT",
  "author": "Tau Contributors",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @tau/desktop dev",
    "build": "pnpm --filter @tau/desktop build",
    "preview": "pnpm --filter @tau/desktop preview",
    "start": "pnpm --filter @tau/desktop start",
    "smoke:package": "pnpm --filter @tau/desktop smoke:package",
    "build:taud": "pnpm --filter @tau/daemon build",
    "test:taud": "pnpm --filter @tau/daemon test",
    "zig:build": "pnpm --filter @tau/daemon build",
    "zig:test": "pnpm --filter @tau/daemon test",
    "zig:lint": "pnpm --filter @tau/daemon lint",
    "zig:fmt": "pnpm --filter @tau/daemon fmt",
    "zig:fmt:check": "pnpm --filter @tau/daemon fmt:check",
    "zig:hardened:compile": "pnpm --filter @tau/daemon hardened:compile",
    "zig:hardened:fmt": "pnpm --filter @tau/daemon hardened:fmt",
    "zig:lsp": "pnpm --filter @tau/daemon lsp",
    "zig:check": "pnpm zig:lint && pnpm zig:fmt:check && pnpm zig:test",
    "zig:leak-check": "pnpm --filter @tau/daemon leak-check",
    "leak:taud": "pnpm zig:leak-check",
    "bench": "pnpm --filter @tau/desktop bench",
    "bench:latency": "pnpm --filter @tau/desktop bench:latency",
    "bench:latency:budget": "pnpm --filter @tau/desktop bench:latency:budget",
    "bench:input-priority:budget": "pnpm --filter @tau/desktop bench:input-priority:budget",
    "bench:attach:budget": "pnpm --filter @tau/desktop bench:attach:budget",
    "bench:workspace:budget": "pnpm --filter @tau/desktop bench:workspace:budget",
    "bench:workspace:large": "pnpm --filter @tau/desktop bench:workspace:large",
    "bench:workspace:large:budget": "pnpm --filter @tau/desktop bench:workspace:large:budget",
    "bench:workspace:xl": "pnpm --filter @tau/desktop bench:workspace:xl",
    "bench:workspace:xl:budget": "pnpm --filter @tau/desktop bench:workspace:xl:budget",
    "bench:soak": "pnpm --filter @tau/desktop bench:soak",
    "bench:soak:budget": "pnpm --filter @tau/desktop bench:soak:budget",
    "bench:renderer": "pnpm --filter @tau/desktop bench:renderer",
    "bench:startup:budget": "pnpm --filter @tau/desktop bench:startup:budget",
    "bench:app-soak": "pnpm --filter @tau/desktop bench:app-soak",
    "bench:app-soak:hour": "pnpm --filter @tau/desktop bench:app-soak:hour",
    "bench:app-soak:budget": "pnpm --filter @tau/desktop bench:app-soak:budget",
    "bench:app-trace": "pnpm --filter @tau/desktop bench:app-trace",
    "bench:app-trace:summary": "pnpm --filter @tau/desktop bench:app-trace:summary",
    "bench:terminal": "pnpm --filter @tau/desktop bench:terminal",
    "bench:terminal:budget": "pnpm --filter @tau/desktop bench:terminal:budget",
    "bench:renderer-combined": "pnpm --filter @tau/desktop bench:renderer-combined",
    "bench:renderer-combined:budget": "pnpm --filter @tau/desktop bench:renderer-combined:budget",
    "bench:file-tree": "pnpm --filter @tau/desktop bench:file-tree",
    "bench:file-tree:budget": "pnpm --filter @tau/desktop bench:file-tree:budget",
    "bench:file-tree:xl": "pnpm --filter @tau/desktop bench:file-tree:xl",
    "bench:file-tree:xl:budget": "pnpm --filter @tau/desktop bench:file-tree:xl:budget",
    "bench:taud:budget": "pnpm --filter @tau/desktop bench:taud:budget",
    "bench:reload:budget": "pnpm --filter @tau/desktop bench:reload:budget",
    "bench:ipc": "pnpm --filter @tau/desktop bench:ipc",
    "bench:ipc:budget": "pnpm --filter @tau/desktop bench:ipc:budget",
    "bench:cross": "pnpm --filter @tau/desktop bench:cross",
    "bench:startup": "pnpm --filter @tau/desktop bench:startup",
    "bench:all": "pnpm --filter @tau/desktop bench:all",
    "test:persistence": "pnpm --filter @tau/desktop test:persistence",
    "postinstall": "tsx scripts/electron-install.ts",
    "fmt": "pnpm fmt:ts && pnpm zig:fmt",
    "fmt:check": "pnpm fmt:ts:check && pnpm zig:fmt:check",
    "fmt:ts": "pnpm exec oxfmt .",
    "fmt:ts:check": "pnpm exec oxfmt --check .",
    "fmt:nix": "nix develop --command nixpkgs-fmt flake.nix",
    "fmt:nix:check": "nix develop --command nixpkgs-fmt --check flake.nix",
    "lint": "pnpm --filter @tau/desktop --filter @tau/shared lint && pnpm zig:lint",
    "lint:fix": "pnpm --filter @tau/desktop --filter @tau/shared lint:fix",
    "check": "pnpm lint && pnpm fmt:check && pnpm tsc && pnpm test:persistence && pnpm zig:test",
    "check:fix": "pnpm lint:fix && pnpm fmt",
    "tsc": "tsc --noEmit -p tsconfig.scripts.json && pnpm --filter @tau/desktop tsc"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "electron": "^42.0.1",
    "oxfmt": "^0.49.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.4"
}
